# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/agent_solve_hub?schema=public"

# JWT Secret
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# Server
PORT=3001

# Email (SMTP)
# 腾讯企业邮箱示例:
# SMTP_HOST=smtp.exmail.qq.com
# SMTP_PORT=465
# SMTP_USER=your-email@yourdomain.com
# SMTP_PASS=your-email-password
# SMTP_FROM=AgentSolveHub <noreply@yourdomain.com>

# QQ邮箱示例:
# SMTP_HOST=smtp.qq.com
# SMTP_PORT=465
# SMTP_USER=your-email@qq.com
# SMTP_PASS=your-authorization-code

# 阿里云邮件推送示例:
# SMTP_HOST=smtp.mx.aliyuncs.com
# SMTP_PORT=465
# SMTP_USER=your-email@yourdomain.com
# SMTP_PASS=your-email-password
